rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function isValidRegistration(data) {
      return data.keys().hasAll(['program', 'name', 'contact', 'reason', 'date', 'createdAt'])
        && data.keys().size() == 6
        && data.program is string && data.program.size() <= 200
        && data.name is string && data.name.size() <= 100
        && data.contact is string && data.contact.size() <= 50
        && data.reason is string && data.reason.size() <= 2000
        && data.date is string && data.date.size() <= 50
        && data.createdAt == request.time;
    }

    match /registrations/{registrationId} {
      allow create: if isValidId(registrationId) && isValidRegistration(request.resource.data);
      allow get, list: if isAdmin();
      allow update, delete: if false;
    }

    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /analytics/{dayId} {
      allow get, list: if isAdmin();
      allow create, update: if isSignedIn(); // Logged in users can increment their visit
    }
    
    match /admins/{adminId} {
      allow get: if isSignedIn() && request.auth.uid == adminId;
      // Allow specific email to bootstrap admin status
      allow create: if isSignedIn() 
        && request.auth.uid == adminId 
        && request.auth.token.email == "odworkroom@odworkroom.local";
      allow list, update, delete: if false;
    }
  }
}
